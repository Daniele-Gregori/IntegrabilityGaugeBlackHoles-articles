Cell[BoxData[
 RowBox[{
  RowBox[{"visualizePixels", "[", 
   RowBox[{"img_Image", ",", 
    RowBox[{"{", 
     RowBox[{"cut1_Integer", ",", "cut2_Integer"}], "}"}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Transpose", "@", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Range", "[", "#", "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"ImageData", "[", "img", "]"}], "[", 
            RowBox[{"[", 
             RowBox[{";;", "#"}], "]"}], "]"}], "//", 
           RowBox[{"Map", "@", "Counts"}]}]}], "}"}]}], "&"}], "@", "cut1"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"Transpose", "@", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Reverse", "@", 
           RowBox[{"Range", "[", 
            RowBox[{
             RowBox[{"-", "#"}], ",", 
             RowBox[{"-", "1"}]}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"Reverse", "@", 
            RowBox[{
             RowBox[{"ImageData", "[", "img", "]"}], "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"-", "#"}], ";;"}], "]"}], "]"}]}], "//", 
           RowBox[{"Map", "@", "Counts"}]}]}], "}"}]}], "&"}], "@", 
      "cut2"}]}], "}"}], "//", 
   RowBox[{"TabView", "@*", 
    RowBox[{"Map", "[", "Grid", "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.952139119035472*^9, 3.9521391976558743`*^9}, {
