  RowBox[{"MapIndexed", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"line", ",", 
        RowBox[{"First", "[", "#2", "]"}]}], "}"}], "->", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"First", "[", "#2", "]"}], ">=", "shift1"}], "&&", 
          RowBox[{
           RowBox[{"First", "[", "#2", "]"}], "<=", "shift2"}]}], ")"}], ",", 
        "repl", ",", "#"}], "]"}]}], "&"}], ",", 
