  RowBox[{"replaceLine", "[", 
   RowBox[{"img_", ",", "line_", ",", 
    RowBox[{"{", 
     RowBox[{"shift1_", ",", "shift2_"}], "}"}], ",", "repl_"}], "]"}], ":=", 
